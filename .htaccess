RewriteEngine On

# Block direct access to hidden files, except ACME/.well-known paths
RewriteRule "(^|/)\.(?!well-known(?:/|$))" - [F]

# Force HTTPS and the apex domain
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/ [NC]
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.vectorworks-spotlight-training\.nl$ [NC]
RewriteRule ^(.*)$ https://vectorworks-spotlight-training.nl/$1 [R=301,L]

# Preserve compatibility with common WordPress sitemap URLs
RewriteRule ^sitemap_index\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^wp-sitemap\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^page-sitemap\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^post-sitemap\.xml$ /sitemap.xml [R=301,L]

<IfModule mod_mime.c>
  AddType text/javascript .ts
</IfModule>

<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; frame-ancestors 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self'; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; media-src 'self'; manifest-src 'self'"
</IfModule>

ErrorDocument 404 /404/index.html
