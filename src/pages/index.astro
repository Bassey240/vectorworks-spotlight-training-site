---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { breadcrumbSchema, organizationSchema, personSchema } from "@/lib/schema";
const schema = [
  organizationSchema(),
  personSchema(),
  breadcrumbSchema([{ label: "Home", href: "/" }])
];
---

<BaseLayout
  title="Vectorworks Spotlight Cursussen | STB Services"
  description="Cursussen, 2D & 3D Tekenwerk en Visualisaties in Vectorworks Spotlight"
  pathname="/"
  image="/wp-content/uploads/2020/04/Vectorworks-Spotlight-Training-STB-Logo-BLACK.png"
  schema={schema}
>
  <!-- ── Hero ── -->
  <section class="home-hero">
    <div class="shell">
      <span class="home-hero__tag">Vectorworks Spotlight Specialist</span>
      <h1 class="home-hero__title">
        De Expert voor de <em>Evenementen&shy;branche</em>
      </h1>
      <p class="home-hero__lead">
        20 jaar ervaring als lichttechnicus, ontwerper en projectmanager.
        Leer Vectorworks Spotlight van iemand die het elke dag gebruikt.
      </p>
      <div class="home-hero__btns">
        <a class="button" href="/trainingen/">Bekijk het aanbod</a>
        <a class="button button--outline-white" href="/aanmelden/">Meld je direct aan</a>
      </div>
      <div class="home-hero__certs">
        <img
          src="/wp-content/uploads/2024/11/ConnectCAD_2024_Professional_Certification_15_Nov_2024_4319a26d.png"
          alt="ConnectCAD Professional Certification"
          width="64"
          height="64"
        />
        <img
          src="/wp-content/uploads/2024/11/Vectorworks_Core_Certification_19_July_2021_fb9a91c9.png"
          alt="Vectorworks Core Certification"
          width="64"
          height="64"
        />
      </div>
    </div>
  </section>

  <!-- ── CTA cards ── -->
  <section class="home-ctas">
    <div class="shell">
    <div class="home-cta-grid">
      <article class="home-cta-card">
        <h2>Zowel Klassikaal Als Online, Groep En Privé Trainingen</h2>
        <p>De Vectorworks Spotlight cursussen zijn live, met een groep vanaf 3 personen. Je kunt individueel of als organisatie aanmelden.</p>
        <a class="button" href="/trainingen/">Bekijk het aanbod</a>
      </article>
      <article class="home-cta-card">
        <h2>Ervaren Trainer Uit De Evenementen Sector</h2>
        <p>Ik ben inmiddels 20 jaar werkzaam in de evenementen sector en werk sinds 2010 intensief met Vectorworks aan uiteenlopende projecten. Technisch én creatief!</p>
        <a class="button" href="/aanmelden/">Meld je direct aan</a>
      </article>
    </div>
    </div>
  </section>

  <!-- ── Render carousel ── -->
  <section class="home-carousel" aria-label="Renders">
    <div class="shell">
    <div class="carousel" id="render-carousel">
      <div class="carousel__track" id="carousel-track">
        <figure class="carousel__slide" aria-hidden="false">
          <img
            src="/wp-content/uploads/2020/06/Vectorworks-Cursus-3D-Rendering-1024x576.png"
            alt="Vectorworks Cursus 3D Rendering"
          />
        </figure>
        <figure class="carousel__slide" aria-hidden="true">
          <img
            src="/wp-content/uploads/2020/06/Vectorworks-Cursus-Technisch-Tekenen-1024x726.png"
            alt="Vectorworks Cursus Technisch Tekenen"
          />
        </figure>
        <figure class="carousel__slide" aria-hidden="true">
          <img
            src="/wp-content/uploads/2020/06/Vectorworks-Spotlight-Training-Back2.png"
            alt="Vectorworks Spotlight Visualisatie"
          />
        </figure>
      </div>

      <button class="carousel__btn carousel__btn--prev" id="carousel-prev" aria-label="Vorige afbeelding">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="carousel__btn carousel__btn--next" id="carousel-next" aria-label="Volgende afbeelding">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <div class="carousel__dots" role="group" aria-label="Ga naar slide">
        <button class="carousel__dot carousel__dot--active" aria-label="Slide 1"></button>
        <button class="carousel__dot" aria-label="Slide 2"></button>
        <button class="carousel__dot" aria-label="Slide 3"></button>
      </div>
    </div>
    </div>
  </section>

  <!-- ── About prose ── -->
  <section class="home-about">
    <div class="shell">
      <div class="prose prose--centered">
        <p>Vectorworks Spotlight Training is een product van STB Services. STB staat voor Sebastiaan ten Broek. Ik ben inmiddels 20 jaar werkzaam in de evenementen sector. Sinds 2010 heb ik mij bekwaamd als Vectorworks tekenaar, dit is mijn passie!</p>
        <p>Regelmatig kreeg ik de vraag van collega&apos;s of ik hen op weg wilde helpen met Vectorworks Spotlight. Ik merkte dat ik het heel erg leuk vond om mijn kennis hierover te delen over anderen. Ook geeft het me veel energie om te merken dat mensen tijdens een cursus net zo enthousiast raken over Vectorworks als mij.</p>
        <p>Mijn ervaring heb ik opgedaan als lichttechnicus, projectmanager, werkvoorbereider en ontwerper. Mijn opdrachtgevers zijn audiovisuele verhuur bedrijven en evenementen productie bedrijven. Zo maak ik sinds een aantal jaar de podium en licht ontwerpen voor Loveland Events B.V.. En heb ik regelmatig opdrachten uitgevoerd voor o.a. PRG, Phlippo en Solid Rental.</p>
        <p>Ik stuur u graag mijn portfolio. Klik hieronder op mijn foto om contact met mij op te nemen.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  (() => {
    const track = document.getElementById("carousel-track") as HTMLElement;
    const slides = document.querySelectorAll<HTMLElement>(".carousel__slide");
    const dots   = document.querySelectorAll<HTMLButtonElement>(".carousel__dot");
    const prev   = document.getElementById("carousel-prev") as HTMLButtonElement;
    const next   = document.getElementById("carousel-next") as HTMLButtonElement;
    const wrap   = document.getElementById("render-carousel") as HTMLElement;

    if (!track || !slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      dots[current].classList.remove("carousel__dot--active");
      slides[current].setAttribute("aria-hidden", "true");
      current = ((index % slides.length) + slides.length) % slides.length;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots[current].classList.add("carousel__dot--active");
      slides[current].removeAttribute("aria-hidden");
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 4000);
    }

    prev.addEventListener("click", () => { goTo(current - 1); startTimer(); });
    next.addEventListener("click", () => { goTo(current + 1); startTimer(); });
    dots.forEach((dot, i) => dot.addEventListener("click", () => { goTo(i); startTimer(); }));

    wrap.addEventListener("mouseenter", () => clearInterval(timer));
    wrap.addEventListener("mouseleave", startTimer);
    wrap.addEventListener("focusin",    () => clearInterval(timer));
    wrap.addEventListener("focusout",   startTimer);

    startTimer();
  })();
</script>
