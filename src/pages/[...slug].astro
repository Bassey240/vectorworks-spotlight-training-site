---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
import SignupForm from "@/components/SignupForm.astro";
import {
  faqHtmlToSchemaText,
  getVideoEmbedSrc,
  sanitizeFaqHtml
} from "@/lib/content-sanitize";
import {
  articleSchema,
  breadcrumbSchema,
  courseSchema,
  faqSchema,
  organizationSchema,
  personSchema,
  serviceSchema
} from "@/lib/schema";

const allPosts = await getCollection("posts");

export async function getStaticPaths() {
  const pageEntries = await getCollection("pages", ({ slug }) => slug !== "home");
  const postEntries = await getCollection("posts");

  return [
    ...pageEntries.map((entry) => ({
      params: { slug: entry.slug.replace(/^\/|\/$/g, "") },
      props: { entry, type: "page" as const }
    })),
    ...postEntries.map((entry) => ({
      params: { slug: entry.slug.replace(/^\/|\/$/g, "") },
      props: { entry, type: "post" as const }
    }))
  ];
}

const DUTCH_MONTHS = [
  "januari",
  "februari",
  "maart",
  "april",
  "mei",
  "juni",
  "juli",
  "augustus",
  "september",
  "oktober",
  "november",
  "december"
];

function formatDutchDate(iso: string): string {
  const [yearStr, monthStr, dayStr] = iso.split("-");
  const year = Number.parseInt(yearStr, 10);
  const month = Number.parseInt(monthStr, 10);
  const day = Number.parseInt(dayStr, 10);
  if (!year || !month || !day) return iso;
  return `${day} ${DUTCH_MONTHS[month - 1]} ${year}`;
}

function buildArchiveSidebar(posts: typeof allPosts) {
  const archiveMap = new Map<string, { label: string; href: string }>();
  for (const post of posts) {
    const [yearStr, monthStr] = post.data.date.split("-");
    const year = Number.parseInt(yearStr, 10);
    const month = Number.parseInt(monthStr, 10);
    if (!year || !month) continue;
    const key = `${yearStr}-${monthStr}`;
    if (!archiveMap.has(key)) {
      archiveMap.set(key, {
        label: `${DUTCH_MONTHS[month - 1]} ${year}`,
        href: `/nieuws/?archief=${key}`
      });
    }
  }
  const archives = [...archiveMap.values()];
  const recentPosts = [...posts]
    .sort((a, b) => b.data.date.localeCompare(a.data.date))
    .slice(0, 5)
    .map((post) => ({ label: post.data.title, href: `/${post.slug}/` }));
  return { archives, recentPosts };
}

const { entry, type } = Astro.props;
const { Content } = await entry.render();
const pathname = `/${entry.slug.replace(/^\/|\/$/g, "")}/`;
const sortedPosts = [...allPosts].sort((a, b) => b.data.date.localeCompare(a.data.date));
const hasBody = (entry.body ?? "").trim().length > 0;
const isPage = type === "page";
const isPost = type === "post";
const isFaqPage = isPage && entry.data.kind === "faq" && entry.data.faqItems;
const isOverviewPage = isPage && entry.data.kind === "overview" && entry.data.cards;
const isArchivePage = isPage && entry.data.kind === "archive";
const isContactPage = isPage && entry.data.kind === "form" && entry.data.formType === "contact";
const isSignupPage = isPage && entry.data.kind === "form" && entry.data.formType === "signup";
const isLegalDocumentPage = isPage && entry.data.kind === "legal" && entry.data.document;
const isAboutPage = isPage && entry.data.kind === "about";
const isFormPage = isContactPage || isSignupPage;
const hasSidebar = isPage && entry.data.sidebar;
const proseClass = pathname === "/over-mij/" ? "prose prose--about" : "prose";
const archiveSidebar = isArchivePage ? buildArchiveSidebar(sortedPosts) : null;
const sanitizedFaqIntro = isFaqPage ? sanitizeFaqHtml(entry.data.faqIntro) : "";
const sanitizedFaqItems = isFaqPage
  ? entry.data.faqItems.map((item) => ({
      question: item.question,
      answerHtml: sanitizeFaqHtml(item.answer),
      answerText: faqHtmlToSchemaText(item.answer)
    }))
  : [];
const videoEmbedSrc = isPost ? getVideoEmbedSrc(entry.data.video?.embed) : "";
const postBodyContainsThumbnail =
  isPost && !!entry.data.thumbnail ? (entry.body ?? "").includes(entry.data.thumbnail) : false;

const schema = [organizationSchema(), personSchema()];

if (isPage) {
  schema.push(
    breadcrumbSchema([
      { label: "Home", href: "/" },
      { label: entry.data.title, href: pathname }
    ])
  );

  if (entry.data.kind === "course") {
    schema.push(
      courseSchema({
        title: entry.data.title,
        description: entry.data.description,
        pathname
      })
    );
  }

  if (entry.data.kind === "service" || entry.data.kind === "about" || entry.data.kind === "form") {
    schema.push(
      serviceSchema({
        title: entry.data.title,
        description: entry.data.description,
        pathname
      })
    );
  }

  if (entry.data.kind === "faq" && entry.data.faqItems) {
    schema.push(
      faqSchema(
        sanitizedFaqItems.map((item) => ({
          question: item.question,
          answer: item.answerText
        }))
      )
    );
  }
} else {
  schema.push(
    breadcrumbSchema([
      { label: "Home", href: "/" },
      { label: "Nieuws", href: "/nieuws/" },
      { label: entry.data.title, href: pathname }
    ]),
    articleSchema({
      title: entry.data.title,
      description: entry.data.description,
      pathname,
      date: entry.data.date
    })
  );
}

const postDateDutch = isPost ? formatDutchDate(entry.data.date) : "";
const showH1 = true; // all pages get the dark gradient page-header
const totalComments = isPost && entry.data.comments
  ? entry.data.comments.reduce((acc, c) => acc + 1 + (c.reply ? 1 : 0), 0)
  : 0;
---

<BaseLayout
  title={entry.data.seoTitle ?? `${entry.data.title} - STB Services`}
  description={entry.data.description}
  pathname={pathname}
  image={entry.data.ogImage}
  schema={schema}
>
  {
    showH1 && (
      <section class="page-header">
        <div class="shell">
          <h1>{entry.data.title}</h1>
          {isPost && (
            <p class="page-intro post-byline">
              <time datetime={entry.data.date}>{postDateDutch}</time>
              {entry.data.author && (
                <>
                  {" · "}
                  {entry.data.authorHref ? (
                    <a href={entry.data.authorHref}>{entry.data.author}</a>
                  ) : (
                    <span>{entry.data.author}</span>
                  )}
                </>
              )}
            </p>
          )}
        </div>
      </section>
    )
  }

  <section class="page-section">
    <div class="shell">
      {
        isOverviewPage ? (
          <>
            {hasBody && (
              <section class="overview-intro notice-band">
                <div class={proseClass}>
                  <Content />
                </div>
              </section>
            )}
            <div class="training-grid">
              {entry.data.cards.map((card) => (
                <article class="training-card">
                  <h3>{card.title}</h3>
                  <p class="training-card__subtitle">{card.subtitle}</p>
                  <p class="training-card__price">€ {card.price}</p>
                  <p class="training-card__period">{card.period}</p>
                  <ul class="training-card__features">
                    {card.features.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                  <a class="button" href={card.href}>{card.buttonLabel ?? "Lees meer..."}</a>
                  {card.footerNote && <p class="training-card__note">{card.footerNote}</p>}
                </article>
              ))}
            </div>
          </>
        ) : null
      }

      {
        isFaqPage ? (
          <div class="content-layout">
            <div class="content-main">
              {sanitizedFaqIntro && (
                <div class="prose faq-intro" set:html={sanitizedFaqIntro} />
              )}
              <div class="faq-card">
                <div class="faq-stack">
                  {sanitizedFaqItems.map((item) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">{item.question}</summary>
                    <div class="prose faq-item__answer" set:html={item.answerHtml} />
                  </details>
                  ))}
                </div>
              </div>
            </div>
            {hasSidebar && (
              <aside class="content-sidebar">
                <div class="sidebar-card">
                  {entry.data.sidebar?.title && <h2 class="sidebar-card__title">{entry.data.sidebar.title}</h2>}
                  {entry.data.sidebar?.paragraphs?.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                  {entry.data.sidebar?.cta && (
                    <a class="button" href={entry.data.sidebar.cta.href}>{entry.data.sidebar.cta.label}</a>
                  )}
                </div>
              </aside>
            )}
          </div>
        ) : null
      }

      {
        isContactPage ? (
          <>
            <h2 class="contact-form__heading">NEEM CONTACT OP</h2>
            <div class="content-layout content-layout--flush">
              <div class="content-main">
                <ContactForm />
              </div>
              <aside class="content-sidebar">
                <div class="sidebar-card">
                  <h2 class="sidebar-card__title">CONTACT</h2>
                  {hasBody && (
                    <div class={proseClass}>
                      <Content />
                    </div>
                  )}
                </div>
              </aside>
            </div>
          </>
        ) : null
      }

      {
        isSignupPage ? (
          <div class="content-main signup-page">
            <h2 class="signup-page__heading">AANMELDEN</h2>
            <SignupForm />
            {hasBody && (
              <div class={`${proseClass} notice-band`}>
                <Content />
              </div>
            )}
          </div>
        ) : null
      }

      {
        isArchivePage ? (
          <div class="content-layout" data-news-archive>
            <div class="content-main">
              <div class="archive-toolbar" data-archive-toolbar hidden>
                <p class="archive-toolbar__status" data-archive-results></p>
                <a class="button button--ghost archive-toolbar__clear" href="/nieuws/" data-archive-clear>
                  Toon alles
                </a>
              </div>
              <div class="archive-grid">
                {sortedPosts.map((post) => {
                  const thumb = post.data.thumbnail;
                  const archiveKey = post.data.date.slice(0, 7);
                  return (
                    <article
                      class="post-teaser"
                      data-archive-item
                      data-archive-month={archiveKey}
                      data-archive-title={post.data.title}
                      data-archive-excerpt={post.data.excerpt}
                    >
                      {thumb && (
                        <a href={`/${post.slug}/`} class="post-teaser__thumb">
                          <img src={thumb} alt={post.data.title} loading="lazy" decoding="async" />
                        </a>
                      )}
                      <h2><a href={`/${post.slug}/`}>{post.data.title}</a></h2>
                      <p class="post-date">
                        {post.data.author && (
                          <>
                            {post.data.authorHref ? (
                              <a href={post.data.authorHref}>{post.data.author}</a>
                            ) : (
                              post.data.author
                            )}
                            {" "}
                          </>
                        )}
                        <time datetime={post.data.date}>{formatDutchDate(post.data.date)}</time>
                      </p>
                      <p>{post.data.excerpt}</p>
                      <a class="button button--ghost" href={`/${post.slug}/`}>Lees meer...</a>
                    </article>
                  );
                })}
              </div>
            </div>
            <aside class="content-sidebar">
              <div class="sidebar-card">
                <form role="search" class="archive-search" action="/nieuws/" method="get">
                  <label>
                    <span>Zoek naar:</span>
                    <input type="search" name="s" placeholder="Zoeken" data-archive-search />
                  </label>
                </form>
              </div>
              {archiveSidebar && archiveSidebar.archives.length > 0 && (
                <div class="sidebar-card">
                  <h5 class="sidebar-card__heading">Archieven</h5>
                  <ul class="sidebar-list">
                    {archiveSidebar.archives.map((a) => (
                      <li><a href={a.href} data-archive-link>{a.label}</a></li>
                    ))}
                  </ul>
                </div>
              )}
              {archiveSidebar && archiveSidebar.recentPosts.length > 0 && (
                <div class="sidebar-card">
                  <h5 class="sidebar-card__heading">Recente berichten</h5>
                  <ul class="sidebar-list">
                    {archiveSidebar.recentPosts.map((r) => (
                      <li><a href={r.href}>{r.label}</a></li>
                    ))}
                  </ul>
                </div>
              )}
            </aside>
          </div>
        ) : null
      }

      {
        isLegalDocumentPage ? (
          <section class="legal-document">
            {entry.data.document.intro && (
              <div class="prose legal-document__intro">
                <p>{entry.data.document.intro}</p>
              </div>
            )}

            <p class="legal-document__actions">
              <a
                class="button"
                href={entry.data.document.pdfHref}
                rel="noreferrer"
                target="_blank"
              >
                {entry.data.document.downloadLabel ?? "Download pdf"}
              </a>
            </p>

            <div
              class="legal-document__viewer"
              data-pdf-viewer
              data-pdf-src={entry.data.document.pdfHref}
              data-pdf-title={entry.data.document.frameTitle ?? entry.data.title}
            >
              <div class="legal-document__loading" data-pdf-loading>
                Pdf wordt geladen...
              </div>
              <p class="legal-document__error" data-pdf-error hidden>
                De pdf kon niet worden geladen.
              </p>
              <div class="legal-document__pages" data-pdf-pages></div>
            </div>
          </section>
        ) : null
      }

      {
        !isOverviewPage && !isFaqPage && !isContactPage && !isSignupPage && !isArchivePage && !isLegalDocumentPage ? (
          hasSidebar ? (
            <div class:list={["content-layout", !isAboutPage && "content-layout--has-sidebar"]}>
              <div class="content-main">
                {hasBody && (
                  isAboutPage ? (
                    <article class="content-story-card">
                      <div class={proseClass}>
                        <Content />
                      </div>
                    </article>
                  ) : (
                    <div class={proseClass}>
                      <Content />
                    </div>
                  )
                )}

                {isPage && entry.data.topics && entry.data.topics.length > 0 && (
                  <section class="topic-box">
                    <h2>Onderwerpen</h2>
                    <div class="topic-columns">
                      <ul>
                        {entry.data.topics.slice(0, Math.ceil(entry.data.topics.length / 2)).map((topic) => (
                          <li>{topic}</li>
                        ))}
                      </ul>
                      <ul>
                        {entry.data.topics.slice(Math.ceil(entry.data.topics.length / 2)).map((topic) => (
                          <li>{topic}</li>
                        ))}
                      </ul>
                    </div>
                  </section>
                )}
              </div>

              <aside class="content-sidebar">
                <div class="sidebar-card">
                  {entry.data.sidebar?.title && <h2 class="sidebar-card__title">{entry.data.sidebar.title}</h2>}
                  {entry.data.sidebar?.paragraphs?.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                  {entry.data.sidebar?.cta && (
                    <a class="button" href={entry.data.sidebar.cta.href}>{entry.data.sidebar.cta.label}</a>
                  )}
                </div>
              </aside>
            </div>
          ) : (
            <>
              {isPost && entry.data.thumbnail && !postBodyContainsThumbnail && (
                <figure class="post-hero-image">
                  <img src={entry.data.thumbnail} alt={entry.data.title} decoding="async" />
                </figure>
              )}

              {hasBody &&
                (isPost ? (
                  <article class="post-story-card">
                    <div class={proseClass}>
                      <Content />
                    </div>
                  </article>
                ) : (
                  <div class={proseClass}>
                    <Content />
                  </div>
                ))}

              {isPage && entry.data.topics && entry.data.topics.length > 0 && (
                <section class="topic-box">
                  <h2>Onderwerpen</h2>
                  <div class="topic-columns">
                    <ul>
                      {entry.data.topics.slice(0, Math.ceil(entry.data.topics.length / 2)).map((topic) => (
                        <li>{topic}</li>
                      ))}
                    </ul>
                    <ul>
                      {entry.data.topics.slice(Math.ceil(entry.data.topics.length / 2)).map((topic) => (
                        <li>{topic}</li>
                      ))}
                    </ul>
                  </div>
                </section>
              )}
            </>
          )
        ) : null
      }

      {
        isPost && entry.data.download ? (
          <section class="notice-band">
            <h2>{entry.data.download.label}</h2>
            <a class="button" href={entry.data.download.href}>Download</a>
          </section>
        ) : null
      }

      {
        isPost && entry.data.video ? (
          <section class="video-embed">
            {videoEmbedSrc ? (
              <div class="video-consent-card">
                {entry.data.thumbnail && (
                  <div class="video-consent-card__thumb">
                    <img src={entry.data.thumbnail} alt={entry.data.title} loading="lazy" decoding="async" />
                  </div>
                )}
                <div class="video-consent-card__body">
                  <h2>Video laden vanaf YouTube</h2>
                  <p>
                    Deze video wordt pas geladen nadat je daarvoor kiest. Pas na die klik maakt je browser contact met YouTube.
                  </p>
                  <div class="video-consent-card__actions">
                    <button
                      class="button"
                      type="button"
                      data-video-load
                      data-video-src={videoEmbedSrc}
                      data-video-title={entry.data.video.label}
                    >
                      Video laden
                    </button>
                    <a class="button button--ghost" href={entry.data.video.href} rel="noreferrer" target="_blank">
                      Bekijk op YouTube
                    </a>
                  </div>
                </div>
                <div class="video-embed__frame" data-video-target hidden></div>
              </div>
            ) : (
              <p>
                Bekijk ook de video op
                {" "}
                <a href={entry.data.video.href} rel="noreferrer" target="_blank">{entry.data.video.label}</a>.
              </p>
            )}
          </section>
        ) : null
      }

      {
        isPost && entry.data.comments && entry.data.comments.length > 0 ? (
          <section class="post-comments">
            <h3>{totalComments} {totalComments === 1 ? "gedachte over" : "gedachten over"} &ldquo;{entry.data.title}&rdquo;</h3>
            <ol class="comment-list">
              {entry.data.comments.map((comment) => (
                <li class="comment">
                  <div class="comment__meta">
                    {comment.authorHref ? (
                      <a class="comment__author" href={comment.authorHref} rel="external nofollow" target="_blank">{comment.author}</a>
                    ) : (
                      <span class="comment__author">{comment.author}</span>
                    )}
                    <span class="comment__date">{comment.date}</span>
                  </div>
                  <div class="comment__body"><p>{comment.body}</p></div>
                  {comment.reply && (
                    <ol class="comment-list comment-list--nested">
                      <li class="comment">
                        <div class="comment__meta">
                          {comment.reply.authorHref ? (
                            <a class="comment__author" href={comment.reply.authorHref} rel="external nofollow" target="_blank">{comment.reply.author}</a>
                          ) : (
                            <span class="comment__author">{comment.reply.author}</span>
                          )}
                          <span class="comment__date">{comment.reply.date}</span>
                        </div>
                        <div class="comment__body"><p>{comment.reply.body}</p></div>
                      </li>
                    </ol>
                  )}
                </li>
              ))}
            </ol>
          </section>
        ) : null
      }

      {
        isPage && entry.data.links && entry.data.links.length > 0 ? (
          <section class="notice-band">
            {entry.data.links.map((item) => (
              <a class="button button--ghost" href={item.href}>{item.label}</a>
            ))}
          </section>
        ) : null
      }
    </div>
  </section>
</BaseLayout>
