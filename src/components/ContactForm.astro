---
import FormStatus from "@/components/FormStatus.astro";
---

<div class="form-shell">
  <FormStatus />
  <form class="site-form" action="/api/contact.php" method="post" novalidate>
    <input type="hidden" name="form_started_at" value="" data-js-timestamp />
    <input type="hidden" name="company_site" value="" />

    <label>
      <span>Bedrijfsnaam</span>
      <input name="company" type="text" autocomplete="organization" maxlength="160" placeholder="Bedrijfsnaam" />
    </label>

    <label>
      <span>Naam *</span>
      <input name="name" type="text" required autocomplete="name" maxlength="120" placeholder="Naam*" />
    </label>

    <label>
      <span>Telefoonnummer *</span>
      <input name="phone" type="tel" required autocomplete="tel" maxlength="60" placeholder="Telefoon nummer*" />
    </label>

    <label>
      <span>E-mailadres *</span>
      <input name="email" type="email" required autocomplete="email" maxlength="254" placeholder="Email*" />
    </label>

    <label>
      <span>Vraag of bericht *</span>
      <textarea name="message" rows="6" required maxlength="5000" placeholder="Uw vraag"></textarea>
    </label>

    <label class="site-form__checkbox">
      <input name="privacy_accepted" type="checkbox" value="1" required />
      <span>Ja, ik ga akkoord met de <a href="/privacyverklaring/">privacyverklaring</a>.</span>
    </label>

    <div class="site-form__altcha">
      <altcha-widget
        challenge="/api/altcha-challenge.php?form=contact"
        auto="onsubmit"
        display="standard"
        name="altcha"
      ></altcha-widget>
      <p class="site-form__altcha-note">Spambeveiliging zonder tracking of cookies.</p>
    </div>

    <button class="button" type="submit">Verzenden</button>
  </form>
</div>
