---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SocialsBlock from "@/components/SocialsBlock.astro";
import { site, toAbsoluteUrl } from "@/lib/site";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname: string;
  image?: string;
  schema?: Array<Record<string, unknown>>;
  showSocials?: boolean;
}

const {
  title,
  description,
  pathname,
  image = "/assets/og-default.svg",
  schema = [],
  showSocials = true
} = Astro.props;

const canonical = toAbsoluteUrl(pathname);
const imageUrl = image.startsWith("http") ? image : toAbsoluteUrl(image);
const plausibleConfig = site.analytics.provider === "plausible" ? site.analytics.plausible : null;
const plausibleScriptUrl =
  site.analytics.enabled && plausibleConfig?.scriptUrl ? plausibleConfig.scriptUrl : null;
const plausibleApiEndpoint =
  plausibleScriptUrl && plausibleConfig?.apiEndpoint ? plausibleConfig.apiEndpoint : null;
const plausibleDataDomain =
  plausibleScriptUrl && plausibleConfig?.dataDomain
    ? plausibleConfig.dataDomain
    : new URL(site.url).hostname;
const includeHomeCarousel = pathname === "/";
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <meta property="og:site_name" content={site.company} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {schema.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#content">Ga naar de inhoud</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    {showSocials && <SocialsBlock />}
    <Footer />
    {plausibleScriptUrl && (
      <script
        defer
        data-domain={plausibleDataDomain}
        data-api={plausibleApiEndpoint || undefined}
        src={plausibleScriptUrl}
      />
    )}
    <script>
      import "@/scripts/altcha";
      import "@/scripts/form-feedback";
      import "@/scripts/form-timestamp";
      import "@/scripts/news-archive-filter";
      import "@/scripts/video-consent";
    </script>
    {includeHomeCarousel && (
      <script>
        import "@/scripts/home-carousel";
      </script>
    )}
  </body>
</html>
